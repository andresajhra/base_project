datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Modulo {
  id        Int       @id @default(autoincrement())
  nombre    String
  ruta_base String
  permisos  Permiso[]
  @@map("modulo")
}

model Permiso {
  id        Int          @id @default(autoincrement())
  modulo_id Int
  accion    String       // "create" | "read" | "update" | "delete"
  recurso   String       // "facturas" | "usuarios"
  activo    Boolean      @default(true)
  modulo    Modulo       @relation(fields: [modulo_id], references: [id])
  roles     RolPermiso[]
  @@unique([modulo_id, accion, recurso])
  @@map("permiso")
}

model Rol {
  id            Int          @id @default(autoincrement())
  nombre        String       @unique
  descripcion   String?
  parent_rol_id Int?
  activo        Boolean      @default(true)
  parent        Rol?         @relation("RolHerencia", fields: [parent_rol_id], references: [id])
  hijos         Rol[]        @relation("RolHerencia")
  permisos      RolPermiso[]
  usuarios      RolUsuario[]
  @@map("rol")
}

model RolPermiso {
  id         Int      @id @default(autoincrement())
  rol_id     Int
  permiso_id Int
  granted_at DateTime @default(now())
  rol        Rol      @relation(fields: [rol_id], references: [id])
  permiso    Permiso  @relation(fields: [permiso_id], references: [id])
  @@unique([rol_id, permiso_id])
  @@map("rol_permiso")
}

model Usuario {
  id         Int          @id @default(autoincrement())
  nombre     String
  password   String
  email      String       @unique
  activo     Boolean      @default(true)
  created_at DateTime     @default(now())
  roles      RolUsuario[]
  @@map("usuario")
}

model RolUsuario {
  id         Int       @id @default(autoincrement())
  rol_id     Int
  usuario_id Int
  desde      DateTime  @default(now())
  hasta      DateTime?           // null = indefinido
  rol        Rol       @relation(fields: [rol_id], references: [id])
  usuario    Usuario   @relation(fields: [usuario_id], references: [id])
  @@unique([rol_id, usuario_id])
  @@map("rol_usuario")
}